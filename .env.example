# =============================================
# 교무지원과 업무 자동화 - 환경 변수 템플릿
# =============================================
# 이 파일을 복사하여 .env 로 이름을 바꾼 뒤,
# 실제 값을 입력하세요.
# .env 파일은 절대 Git에 커밋하지 마세요!
# =============================================

# Google Gemini API
GEMINI_API_KEY=

# ── 업무 인사이트 대시보드 업로더 ──────────────────────
# UPLOAD_METHOD: "supabase" 또는 "api" (기본값: api)
UPLOAD_METHOD=api

# [방법 1] Supabase 연동
# Supabase 프로젝트 대시보드 → Settings → API 에서 확인
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_KEY=<anon-public-key>

# [방법 2] Vercel 대시보드 REST API
DASHBOARD_API_URL=https://gyomu-dashboard.vercel.app/api/insights
DASHBOARD_API_SECRET=          # Bearer 토큰 (API Route에서 검증할 경우 설정)
# UPSERT_MODE=true              # true: 서버가 upsert 처리 / false: GET→POST/PUT 전략

# Notion API (사용 안 함 - 참고용)
# NOTION_API_KEY=
# NOTION_DATABASE_ID=

# Google Sheets / Drive (서비스 계정 JSON 경로)
GOOGLE_SERVICE_ACCOUNT_JSON=

# 기타 설정
APP_ENV=development
LOG_LEVEL=INFO
